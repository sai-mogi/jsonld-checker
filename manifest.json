{
  "manifest_version": 3,
  "name": "JSON-LD Checker",
  "version": "1.0.0",
  "description": "JSON-LDの構文エラー・不足プロパティを検出します",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "icons": {
    "48": "icon.png",
    "128": "icon128.png"
  }
}
